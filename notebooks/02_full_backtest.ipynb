import numpy as np

def sanity_check(df):
    print("\n===== PIPELINE SANITY CHECK =====\n")

    cols = ["signal", "position", "book_pnl", "strategy_pnl"]

    for c in cols:
        if c not in df.columns:
            print(f"❌ Missing column: {c}")
            continue

        print(f"\n--- {c} ---")
        print("NaNs:", df[c].isna().sum())
        print("Infs:", np.isinf(df[c]).sum())
        print("Min:", df[c].min())
        print("Max:", df[c].max())
        print("Std:", df[c].std())

        # detect "collapsed distributions"
        unique_ratio = df[c].nunique() / len(df)
        print("Unique ratio:", round(unique_ratio, 4))

