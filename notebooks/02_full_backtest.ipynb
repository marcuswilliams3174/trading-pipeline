import pandas as pd
import numpy as np

# =========================
# 1. LOAD STORAGE (clean)
# =========================
storage = pd.read_excel("NG_STOR_WKLY_S1_W (1).xls", sheet_name=0)

storage = storage.rename(columns={
    "Date": "date",
    storage.columns[1]: "lower48_storage"
})

storage["date"] = pd.to_datetime(storage["date"])
storage = storage[["date", "lower48_storage"]].dropna()

storage = storage.sort_values("date")

# =========================
# 2. LOAD PRICE (FIXED)
# =========================
url = "https://www.eia.gov/dnav/ng/hist_xls/RNGWHHDd.xls"
price = pd.read_excel(url, sheet_name=0, skiprows=2)

# find correct columns
price = price.iloc[:, [0, 1]]
price.columns = ["date", "price"]

price["date"] = pd.to_datetime(price["date"], errors="coerce")
price["price"] = pd.to_numeric(price["price"], errors="coerce")

price = price.dropna().sort_values("date")

# =========================
# 3. MERGE DATA
# =========================
model = storage.merge(price, on="date", how="inner")

# =========================
# 4. FEATURES
# =========================
model["wow_change"] = model["lower48_storage"].diff()

model["storage_z"] = (
    (model["lower48_storage"] - model["lower48_storage"].rolling(52).mean()) /
    model["lower48_storage"].rolling(52).std()
)

# simple regime
model["winter"] = model["date"].dt.month.isin([11, 12, 1, 2])
model["summer"] = model["date"].dt.month.isin([6, 7, 8])

model["fundamental_score"] = 0.0

model.loc[model["winter"], "fundamental_score"] = -model["storage_z"] * 0.7
model.loc[model["summer"], "fundamental_score"] = model["storage_z"] * 0.3
model.loc[~(model["winter"] | model["summer"]), "fundamental_score"] = -model["storage_z"] * 0.4

model = model.dropna()

# =========================
# 5. POSITIONING
# =========================
model["position"] = 0
model.loc[model["fundamental_score"] > 0.5, "position"] = 1
model.loc[model["fundamental_score"] < -0.5, "position"] = -1

# =========================
# 6. RETURNS + BACKTEST
# =========================
model["returns"] = model["price"].pct_change()
model["strategy_returns"] = model["position"].shift(1) * model["returns"]

model = model.dropna()

equity = (1 + model["strategy_returns"]).cumprod()

print("Rows:", len(model))
print("Total Return:", equity.iloc[-1] - 1)
print("Mean Return:", model["strategy_returns"].mean())
print("Volatility:", model["strategy_returns"].std())
print("Sharpe:", model["strategy_returns"].mean() / model["strategy_returns"].std() * np.sqrt(252))

