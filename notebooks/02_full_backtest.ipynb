import pandas as pd
import numpy as np
from pandas_datareader import data as web

start = model["date"].min()
end = model["date"].max()

temp = web.DataReader("USW00094846", "ghcn", start, end)  # Chicago station proxy
temp = temp.reset_index()

temp = temp.rename(columns={"date": "date", "value": "temp"})
temp = temp[["date", "temp"]]

temp.head()

np.random.seed(7)

temp = pd.DataFrame({
    "date": model["date"],
    "temp": 50 + 20*np.sin(np.arange(len(model))/52) + np.random.normal(0, 5, len(model))
})

base_temp = 65

temp["HDD"] = np.maximum(0, base_temp - temp["temp"])
temp["CDD"] = np.maximum(0, temp["temp"] - base_temp)

model = pd.merge(model, temp, on="date", how="left")

model[["HDD", "CDD"]] = model[["HDD", "CDD"]].fillna(0)
model.head()

model["weather_signal"] = model["HDD"] - model["CDD"]
model["weather_signal"] = (model["weather_signal"] - model["weather_signal"].mean()) / model["weather_signal"].std()

model["fundamental_score"] = (
    -model["storage_z"] +
    -model["wow_change"] * 0.001 +
    model["weather_signal"] * 0.5
)

model["position"] = 0

model.loc[model["fundamental_score"] > 0.5, "position"] = 1
model.loc[model["fundamental_score"] < -0.5, "position"] = -1

model["position"] = model["position"].shift(1)

model["returns"] = np.log(model["ng_price"]).diff()

model["strategy_returns"] = (
    model["position"].fillna(0) *
    model["returns"].fillna(0) *
    10
)

bt = model.dropna(subset=["strategy_returns"]).copy()
bt["equity"] = bt["strategy_returns"].cumsum()

print("Rows:", len(bt))
print("Total Return:", bt["equity"].iloc[-1])
print("Sharpe:", bt["strategy_returns"].mean() / bt["strategy_returns"].std() * np.sqrt(52))

model["winter_regime"] = model["HDD"] > model["HDD"].median()

model["summer_regime"] = model["CDD"] > model["CDD"].median()

model["fundamental_score"] = 0

# WINTER: HDD dominates
model.loc[model["winter_regime"], "fundamental_score"] = (
    -model["storage_z"]
    + model["weather_signal"]
)

# SUMMER: CDD dominates
model.loc[model["summer_regime"], "fundamental_score"] = (
    -model["storage_z"] * 0.5
    - model["weather_signal"]
)

# SHOULDER: storage dominates
model.loc[~(model["winter_regime"] | model["summer_regime"]), "fundamental_score"] = (
    -model["storage_z"]
)

model["position"] = 0

model.loc[model["fundamental_score"] > 0.5, "position"] = 1
model.loc[model["fundamental_score"] < -0.5, "position"] = -1

model["position"] = model["position"].shift(1)

model["returns"] = np.log(model["ng_price"]).diff()

model["strategy_returns"] = (
    model["position"].fillna(0) *
    model["returns"].fillna(0) *
    10
)

bt = model.dropna(subset=["strategy_returns"]).copy()
bt["equity"] = bt["strategy_returns"].cumsum()

print("Rows:", len(bt))
print("Total Return:", bt["equity"].iloc[-1])
print("Sharpe:", model["strategy_returns"].mean() / model["strategy_returns"].std() * np.sqrt(52))


import numpy as np

# -----------------------------
# 1. SAFETY RESET (avoid dtype + overwrite issues)
# -----------------------------
model = model.copy()

model["fundamental_score"] = 0.0

# -----------------------------
# 2. REGIME DEFINITIONS (safe)
# -----------------------------
model["winter_regime"] = model["HDD"] > model["HDD"].median()
model["summer_regime"] = model["CDD"] > model["CDD"].median()

# -----------------------------
# 3. REGIME-BASED SIGNAL
# -----------------------------
model.loc[model["winter_regime"], "fundamental_score"] = (
    -model["storage_z"] + model["weather_signal"]
)

model.loc[model["summer_regime"], "fundamental_score"] = (
    -model["storage_z"] * 0.5 - model["weather_signal"]
)

model.loc[~(model["winter_regime"] | model["summer_regime"]), "fundamental_score"] = (
    -model["storage_z"]
)

# -----------------------------
# 4. POSITION LOGIC
# -----------------------------
model["position"] = 0

model.loc[model["fundamental_score"] > 0.5, "position"] = 1
model.loc[model["fundamental_score"] < -0.5, "position"] = -1

model["position"] = model["position"].shift(1)

# -----------------------------
# 5. RETURNS + STRATEGY
# -----------------------------
model["returns"] = np.log(model["ng_price"]).diff()

model["strategy_returns"] = (
    model["position"].fillna(0) *
    model["returns"].fillna(0) *
    10
)

# -----------------------------
# 6. BACKTEST
# -----------------------------
bt = model.dropna(subset=["strategy_returns"]).copy()

bt["equity"] = bt["strategy_returns"].cumsum()

# -----------------------------
# 7. OUTPUT
# -----------------------------
print("Rows:", len(bt))
print("Total Return:", bt["equity"].iloc[-1])

sharpe = (
    bt["strategy_returns"].mean()
    / bt["strategy_returns"].std()
    * np.sqrt(52)
)

print("Sharpe:", sharpe)

