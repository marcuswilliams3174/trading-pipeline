import pandas as pd
import numpy as np

model = model.copy()

model["date"] = pd.to_datetime(model["date"])
model["month"] = model["date"].dt.month

# seasonal average price by month (proxy curve)
seasonal_curve = model.groupby("month")["ng_price"].transform("mean")

model["seasonal_price"] = seasonal_curve

model["seasonal_dislocation"] = (
    np.log(model["ng_price"]) - np.log(model["seasonal_price"])
)

model["signal"] = (
    -model["storage_z"] +
    model["weather_signal"] -
    model["seasonal_dislocation"] * 2
)

model["signal"] = model["signal"].rolling(3).mean()

model["position"] = 0

model.loc[model["signal"] > 0.5, "position"] = 1
model.loc[model["signal"] < -0.5, "position"] = -1

model["position"] = model["position"].shift(1)
model["position"] = model["position"].clip(-1, 1)

model["returns"] = np.log(model["ng_price"]).diff()

model["strategy_returns"] = (
    model["position"].fillna(0) *
    model["returns"].fillna(0) *
    10
)

bt = model.dropna(subset=["strategy_returns"]).copy()

bt["equity"] = bt["strategy_returns"].cumsum()

print("Rows:", len(bt))
print("Total Return:", bt["equity"].iloc[-1])
print("Sharpe:", model["strategy_returns"].mean() / model["strategy_returns"].std() * np.sqrt(52))

