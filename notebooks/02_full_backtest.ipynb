base_signal = -model["fundamental_score"]

regime_multiplier = np.where(model["winter_regime"] == 1, 1.2, 0.8)

event_multiplier = np.where(model["event_state"] == 1, 1.5, 0.7)

model["position_raw"] = (
    base_signal *
    regime_multiplier *
    event_multiplier *
    model["vol_scalar"]
)

model["position"] = np.tanh(model["position_raw"])

