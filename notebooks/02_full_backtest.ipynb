import pandas as pd
import numpy as np

import os
os.listdir()

import pandas as pd

storage = pd.read_excel(
    "NG_STOR_WKLY_S1_W (1).xls",
    sheet_name="Data 1",
    skiprows=2
)

storage.head()

storage = storage.rename(columns={
    storage.columns[0]: "date",
    storage.columns[1]: "lower48_storage"
})

storage = storage[["date", "lower48_storage"]]

storage["date"] = pd.to_datetime(storage["date"])

storage["lower48_storage"] = pd.to_numeric(
    storage["lower48_storage"],
    errors="coerce"
)

storage = storage.dropna()

storage.head()

storage["wow_change"] = storage["lower48_storage"].diff()

storage.head()

storage["storage_z"] = (
    storage["lower48_storage"]
    - storage["lower48_storage"].rolling(52).mean()
) / storage["lower48_storage"].rolling(52).std()

storage.tail()

import numpy as np

model = storage.copy()

model["fundamental_score"] = (
    -model["storage_z"]              # tight storage = bullish
    - model["wow_change"] * 0.001    # withdrawals = bullish
)

model.head()

model["position"] = 0

model.loc[model["fundamental_score"] > 1, "position"] = 1
model.loc[model["fundamental_score"] < -1, "position"] = -1

model["position"] = model["position"].shift(1)

model[["date", "fundamental_score", "position"]].tail()

np.random.seed(7)

model["ng_price"] = 3 + np.cumsum(
    np.random.normal(0, 0.05, len(model))
)

model[["date", "ng_price"]].tail()

model["returns"] = model["ng_price"].pct_change()

model[["date", "returns"]].tail()

model["strategy_returns"] = model["position"] * model["returns"]

model[["date", "position", "returns", "strategy_returns"]].tail()

model["strategy_returns"].cumsum().tail()

# Remove NaNs
bt = model.dropna().copy()

# Equity curve
bt["equity"] = bt["strategy_returns"].cumsum()

# Basic stats
total_return = bt["equity"].iloc[-1]
vol = bt["strategy_returns"].std()
sharpe = bt["strategy_returns"].mean() / vol * np.sqrt(52)

print("Total Return:", total_return)
print("Volatility:", vol)
print("Sharpe:", sharpe)

